{
  "name": "vimx-mcp",
  "version": "0.1.1",
  "description": "MCP server giving AI agents Vimium-like browser control via Chrome DevTools Protocol — affordance-typed actions over filtered, hit-tested element refs.",
  "license": "MIT",
  "author": "Łukasz Kryczka <lukasz.kryczka000@gmail.com>",
  "homepage": "https://github.com/kryczkal/vimx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kryczkal/vimx.git"
  },
  "bugs": {
    "url": "https://github.com/kryczkal/vimx/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vimx-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "THIRD-PARTY-NOTICES.md",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "browser-automation",
    "chrome",
    "cdp",
