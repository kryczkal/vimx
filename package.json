    "ai-agent",
    "agent",
    "llm",
    "claude",
    "vimium"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chrome-remote-interface": "^0.34.0",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5"
  }
